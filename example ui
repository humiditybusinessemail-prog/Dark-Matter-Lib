-- SETTINGS TAB
------------------------------------------------------------------------
local SettingsSec = SettingsTab:CreateSection("Settings Configs")

SettingsSec:CreateButton("Print Loaded Modules", function()
    print("[DARK MATTER CONFIG]: Module running on: " .. tostring(os.date("%X")))
end)

SettingsSec:CreateButton("Copy Discord Server", function()
    if setclipboard then
        setclipboard("https://discord.gg/darkmatter")
        print("[DARK MATTER]: Server Link Copied to Clipboard!")
    else
        print("[DARK MATTER WARNING]: Executor clipboard function unsupported.")
    end
end)

